{% extends 'base.html.twig' %}

{% block meta %}
    {% include 'common/parts/meta.html.twig' with {
        'title': portfolioCategory.metaTitle,
        'description': portfolioCategory.metaDescription,
        'ogTitle': portfolioCategory.ogTitle,
        'ogDescription': portfolioCategory.ogDescription,
        'ogImage': host ~ '/uploads/category/' ~ portfolioCategory.ogImage
    } %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('portfolio-page') }}
{% endblock %}

{% block content %}
    <section class="content">
        <h1 class="content__header">{{ portfolioCategory.title }}</h1>
        {% if portfolioCategory.description is not null %}
            <p class="content__simple-text">{{ portfolioCategory.description }}</p>
        {% endif %}
        {% for case in cases %}
            <a href="{{ path('app_case_page', { 'slug' : case.seoUrl }) }}" class="blog-item__link">
            <div class="blog-item">
                <h2 class="blog-item__title">{{ case.title }}</h2>

                <div class="blog-item__data">
                    <p class="blog-item__description">{{ case.description }}</p>
                    {% if case.mainImage is not null %}
                        <div class="blog-item__img-container">
                            <img
                                    src="/uploads/post/{{ case.mainImage }}"
                                    alt="{{ case.title }}"
                                    class="blog-item__img"
                            />
                        </div>
                    {% endif %}
                </div>
            </div>
            </a>
        {% endfor %}
    </section>
{% endblock %}
