{% extends 'base.html.twig' %}

{% block meta %}
    {% include 'common/parts/meta.html.twig' with {
        'title': 'My cases | Artem Burykin',
        'description': 'Here are examples of tasks I solved',
        'ogTitle': 'My cases | Artem Burykin',
        'ogDescription': 'Here are examples of tasks I solved',
        'ogImage': host ~ asset('build/images/cases-og.png')
    } %}
{% endblock %}

{% block stylesheets %}
