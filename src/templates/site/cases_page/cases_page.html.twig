    {{ encore_entry_link_tags('cases-page') }}
{% endblock %}

{% block content %}
    <section class="content">

    <h1 class="content__header">My cases</h1>
        {% include 'common/parts/posts.html.twig' with {'posts': posts, 'postUrl': 'app_case_page'} %}
    </section>
{% endblock %}
