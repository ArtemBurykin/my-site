{% extends 'base.html.twig' %}

{% block meta %}
    {% include 'common/parts/meta.html.twig' with {
        'title': 'Наш блог | АВЕ Системз',
        'description': 'Здесь мы делимся последними новостями, интересными идеями и подробностями о нашей работе. Получите уникальный взгляд на наш творческий процесс и то, как мы воплощаем идеи в жизнь.',
        'ogTitle': 'Наш блог | АВЕ Системз',
        'ogDescription': 'Здесь мы делимся последними новостями, интересными идеями и подробностями о нашей работе. Получите уникальный взгляд на наш творческий процесс и то, как мы воплощаем идеи в жизнь.',
        'ogImage': host ~ asset('build/images/blog-og.webp')
    } %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('blog-page') }}
{% endblock %}

{% block content %}
    <section class="content">

    <h1 class="content__header">Наш блог</h1>
    {% for post in posts %}
        <a href="{{ path('app_post_page', { 'slug' : post.seoUrl }) }}" class="blog-item__link">
            <div class="blog-item">
                <h2 class="blog-item__title">{{ post.title }}</h2>
                <p class="blog-item__date">{{ post.createdAt |date("d.m.Y G:i") }}</p>

                <div class="blog-item__data">
                    <p class="blog-item__description">{{ post.description }}</p>
                    {% if post.mainImage is not null %}
                        <div class="blog-item__img-container">
                            <img
                                    src="/uploads/post/{{ post.mainImage }}"
                                    alt="{{ post.title }}"
                                    class="blog-item__img"
                            />
                        </div>
                    {% endif %}
                </div>
            </div>
        </a>
    {% endfor %}

    {% include 'common/parts/pagination.html.twig' with {
        'page': page,
        'pagination': pagination,
        'baseUrl': path('app_blog_page')
    } %}
    </section>
{% endblock %}
